# Copy this file to .env and fill in your keys.
# .env is loaded automatically by `langgraph dev` and LangSmith Deployment.

# Required: LLM
ANTHROPIC_API_KEY=your-anthropic-key-here
# Optional: defaults to claude-sonnet-4-6 (see Anthropic model docs)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Required: web search tool
TAVILY_API_KEY=your-tavily-key-here

# Required for LangSmith Deployment and tracing
LANGSMITH_API_KEY=your-langsmith-key-here

# Travel planner web UI (`web/`) — proxy calls this deployment (no trailing slash)
# DEPLOYMENT_URL=https://your-deployment.langsmith.com

# Optional: defaults to travel_planner (see langgraph.json)
# LANGGRAPH_ASSISTANT_ID=travel_planner

# Optional: local API port for `npm run dev` in web/ (default 3847)
# API_PORT=3847

# Optional: enables LangSmith tracing locally (set to "true" to turn on)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=travel-planner-agent
